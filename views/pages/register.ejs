<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
        <link rel="stylesheet" href="./styles/global.css">
        <link rel="stylesheet" href="./styles/robot.css">
        <link rel="stylesheet" href="./styles/register.css">
        <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>

        <title>Socket-shooter | Sign Up</title>
</head>

<body>
    <header>
        <%- include('../partials/header'); %>
    </header>

    <link href='https://fonts.googleapis.com/css?family=Lato:300,400,700' rel='stylesheet' type='text/css'>
    <!--<div id='stars'></div>
    <div id='stars2'></div>
    <div id='stars3'></div> -->
    <div class="register-container">
        <form class="registerForm" id="registerForm">
            <div class="mb-3">
                <h2>Register</h2>
            </div>
            <div class="mb-3">
                <label for="usernameLabel" class="form-label">Username</label>
                <input type="text" class="form-control" id="username" placeholder="player123">
            </div>
            <div class="mb-3">
                <label for="emailLabel" class="form-label">Email</label>
                <input type="text" class="form-control" id="email" placeholder="player@mail.com">
            </div>
            <div class="mb-3">
                <label for="passwordLabel" class="form-label">Password</label>
                <input type="password" class="form-control" id="password" placeholder="Write your password here">
            </div>
            <!--<div class="mb-3 form-check">
            <input type="checkbox" class="form-check-input" id="exampleCheck1">
            <label class="form-check-label" for="exampleCheck1">Check me out</label>
        </div>-->
            <button type="submit" class="btn btn-primary">Register</button>
        </form>
    </div>
    <script src='//cdnjs.cloudflare.com/ajax/libs/jquery/2.1.3/jquery.min.js'></script>
    <script src="./service/register.js"></script>
</body>

</html>