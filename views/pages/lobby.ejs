<!DOCTYPE html>
<html lang="en">

<head>

    <%- include('../partials/head'); %>
    <link rel="stylesheet" href="./styles/lobby.css">
    <title>Socket-shooter | Hobby</title>

</head>
<body class="bg-transparent">

    <header>
        <!-- user variable comes from our server.js route -->
        <%- include('../partials/header', { user }); %>
    </header>


    <link href='https://fonts.googleapis.com/css?family=Lato:300,400,700' rel='stylesheet' type='text/css'>
    <div id='stars'></div>
    <div id='stars2'></div>
    <div id='stars3'></div>

    <div class="clients_container ">
        <div class="container-fluid">
            <div class="container bg-transparent ">
                <div class="card bg-none bg-transparent">
                    <div class="card-body bg-none bg-transparent">
                            <div class="row d-flex justify-content-center ">
                                <div class="col-5 st_client_name d-flex justify-content-center bg-none">
                                    <%= user.username %>
                                </div>
                                <div class="col-5 nd_client_name d-flex justify-content-center bg-none">client2</div>
                            </div>
                            <div class="row d-flex justify-content-center ">
                                <div class="col-5 st_client_status d-flex justify-content-center bg-none">Ready</div>
                                <div class="col-5 nd_client_status d-flex justify-content-center bg-none">Waiting</div>
                            </div>
                            <div class="row d-flex justify-content-center ">
                                <div class="col-10 d-flex justify-content-center">
                                    <button id="btnStartGame" class="btn btn-primary mt-4 px-5 py-3" >START</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    <script src='//cdnjs.cloudflare.com/ajax/libs/jquery/2.1.3/jquery.min.js'></script>

    <script src="../service/logout.js"></script>

</body>
</html>